# OpenAI-호환 LLM 클라이언트 환경 변수 템플릿.
# 본 파일은 git에 커밋된다. 실제 값은 .env에 복사해서 사용 (.env는 gitignore됨).
#
# OpenAI Python SDK가 아래 변수를 자동 인식하므로 코드는 provider에 무관하다.
# OpenAI 호환 endpoint면 어떤 backend(OpenAI, OpenRouter, Together, Groq,
# 로컬 vLLM 등)든 동일하게 동작한다.

OPENAI_API_KEY=
OPENAI_BASE_URL=
# LLM_MODEL=          # 선택; CLI --model로도 지정 가능
# LLM_MODEL_ALIAS=    # 선택; 같은 weights를 다른 routing slug로 부를 때 캐시 키로
                      # 사용할 안정적 이름. 예: LLM_MODEL이 `openai/gpt-oss-120b:free`
                      # ↔ `openai/gpt-oss-120b:nitro` 사이를 오가도 alias가 같으면
                      # 캐시 hit. 미지정 시 LLM_MODEL 그대로 사용 (legacy 동작).

# 파인튜닝(`train` 명령)용 — Hugging Face 토큰.
# Gemma/T5Gemma 등 gated 모델 다운로드에 필요. 모델 페이지에서 라이선스 동의 후
# https://huggingface.co/settings/tokens 의 Read 토큰을 넣는다. (`train` 그룹 설치 필요)
# HF_TOKEN=